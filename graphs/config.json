{
  "defaults": {
    "include_types": [
      "code",
      "document"
    ],
    "_include_types_ref": "all graphify categories: code (source files), document (md/rst/txt/yaml/json), paper (pdf), image (png/jpg/gif/svg), video (mp4/mp3/wav). omit a category to skip it during extraction."
  },
  "_keywords_ref": "Repo.keywords drives Tier-2 auto-select alongside the tokenized repo name. Matching is case-insensitive substring of (keyword OR repo-name-token) against the question text. Repo-name tokens are derived by splitting on '-' and excluding the stopwords 'mattermost' and 'plugin' (e.g. 'mattermost-plugin-github' tokenizes to ['github']). Only add a keyword if it provides routing the implicit token does not - i.e. the keyword must NOT contain any token as a substring (otherwise the token already catches every question the keyword would). Examples of legitimate keywords: 'focalboard' (the plugin ID for mattermost-plugin-boards, contains no 'boards' substring), 'mattermost-ai' (the plugin ID for mattermost-plugin-agents, contains no 'agents' substring), 'electron' for desktop. Counter-example: 'com.mattermost.calls' is redundant on mattermost-plugin-calls because the substring 'calls' inside it already matches the token. The server bundle is queried unconditionally; non-server bundles are queried in decreasing |bundle.repos intersect R| order; per-repo scopes are queried for matched repos not covered by any queried bundle. See notes/docs-repo-in-bundles-deferred.md.",
  "repos": {
    "rtcd": {
      "scope": "full",
      "keywords": ["RTC", "ICE", "TURN", "STUN"]
    },
    "calls-offloader": {
      "scope": "full"
    },
    "calls-recorder": {
      "scope": "full",
      "keywords": ["recording"]
    },
    "calls-transcriber": {
      "scope": "full",
      "keywords": ["transcription"]
    },
    "mattermost-plugin-calls": {
      "scope": "full",
      "include_types": [
        "code",
        "document"
      ]
    },
    "mattermost-plugin-github": {
      "scope": "full"
    },
    "mattermost-plugin-gitlab": {
      "scope": "full"
    },
    "mattermost-plugin-jira": {
      "scope": "full"
    },
    "mattermost-plugin-zoom": {
      "scope": "full"
    },
    "mattermost-plugin-mscalendar": {
      "scope": "full"
    },
    "mattermost-plugin-msteams": {
      "scope": "full"
    },
    "mattermost-plugin-msteams-meetings": {
      "scope": "full"
    },
    "mattermost-plugin-google-calendar": {
      "scope": "full",
      "keywords": ["gcal"]
    },
    "mattermost-plugin-agents": {
      "scope": "full",
      "keywords": ["mattermost-ai", "MCP", "LLM provider"]
    },
    "mattermost-plugin-boards": {
      "scope": "full",
      "keywords": ["focalboard"]
    },
    "mattermost-plugin-playbooks": {
      "scope": "full"
    },
    "mattermost-plugin-channel-automation": {
      "scope": "full"
    },
    "enterprise": {
      "scope": "full",
      "keywords": ["ldap", "saml", "sso", "high availability", "cluster", "elasticsearch", "compliance", "data retention", "access control"]
    },
    "migration-assist": {
      "scope": "full",
      "keywords": ["mysql to postgres"]
    },
    "docker": {
      "scope": "full"
    },
    "mattermost-helm": {
      "scope": "full"
    },
    "mattermost-operator": {
      "scope": "full",
      "keywords": ["k8s"]
    },
    "desktop": {
      "scope": "full",
      "keywords": ["electron"]
    },
    "docs": {
      "scope": "subdirs",
      "_keywords_ref": "Broad-concept terms only - docs graph delivers conceptual neighborhoods grep would miss (adjacent topics like 'Transport Encryption' surfacing on a 'gossip compression' question). For specific config keys (MaxOpenConns, EnableGossipCompression, etc.), the docs graph returns 0 hits - Tier 1.5 grep on upstream/docs/source/ remains the primary docs surface. See notes/docs-repo-in-bundles-deferred.md.",
      "keywords": ["high availability", "scaling", "deployment guide", "admin guide", "disaster recovery", "backup", "performance tuning", "encryption at rest", "transport encryption", "configuration reference", "system console path", "ldap setup", "saml setup", "push notification setup", "elasticsearch setup", "mobile deployment", "kubernetes deployment"],
      "paths": [
        "source/_generated/agents/docs",
        "source/administration-guide/comply",
        "source/administration-guide/configure",
        "source/administration-guide/manage",
        "source/administration-guide/onboard",
        "source/administration-guide/scale",
        "source/administration-guide/upgrade",
        "source/deployment-guide",
        "source/end-user-guide",
        "source/security-guide",
        "source/integrations-guide"
      ]
    },
    "mattermost-mobile": {
      "scope": "subdirs",
      "keywords": ["push notification", "react native", "iOS", "Android"],
      "paths": [
        "app/screens",
        "app/components",
        "app/products",
        "app/database",
        "app/client",
        "app/actions",
        "app/utils",
        "app/hooks",
        "libraries",
        "types",
        "ios",
        "android"
      ]
    },
    "mattermost": {
      "scope": "subdirs",
      "keywords": ["system console", "config.json", "support packet", "MaxOpenConns", "MaxIdleConns", "WebSocket", "session", "channels api"],
      "paths": [
        "api",
        "server/public/model",
        "server/public/plugin",
        "server/einterfaces",
        "server/config",
        "server/cmd/mmctl",
        "server/i18n",
        "server/channels/api4",
        "server/channels/app",
        "server/channels/store/sqlstore",
        "server/channels/jobs",
        "server/channels/wsapi",
        "webapp/platform",
        "webapp/channels/src/actions",
        "webapp/channels/src/client",
        "webapp/channels/src/plugins",
        "webapp/channels/src/hooks",
        "webapp/channels/src/selectors",
        "webapp/channels/src/reducers",
        "webapp/channels/src/store"
      ]
    }
  },
  "bundles": {
    "calls": {
      "repos": [
        "mattermost",
        "mattermost-plugin-calls",
        "rtcd",
        "calls-offloader",
        "calls-recorder",
        "calls-transcriber"
      ]
