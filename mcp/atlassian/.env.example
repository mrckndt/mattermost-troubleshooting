# Mattermost internal Jira (Cloud) credentials for sooperset/mcp-atlassian.
# Copy to mcp/atlassian/.env and fill in. .env is gitignored - never commit real tokens.
JIRA_URL=https://mattermost.atlassian.net
JIRA_USERNAME=you@mattermost.com
# Create a token at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# Investigation defaults: read-only, scoped to internal Jira (MM) project keys.
READ_ONLY_MODE=true
JIRA_PROJECTS_FILTER=MM
