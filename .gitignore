# Ignore everything by default
*

# Track this file
!.gitignore

# Track top-level docs
!CLAUDE.md
!README.md

# Track upstream folder
!upstream/

# Track curated per-repo notes
!claude-md/
!claude-md/**

# Track only specific .claude paths
!.claude/
!.claude/commands/
!.claude/commands/**
!.claude/helpers/
!.claude/helpers/**
!.claude/settings.local.json

# Track only graphs/config.json; ignore all built graph outputs and .active_scope
!graphs/
!graphs/config.json

# macOS
.DS_Store
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes
__MACOSX/

# Neovim / Vim
.netrwhist
Session.vim
.viminfo

# VS Code
.vscode/

# Defensive: never commit API keys, even if the allowlist above is later relaxed.
# Last rule wins in git, so these stay ignored even if `.claude/**` becomes tracked.
.claude/GEMINI_API_KEY
.claude/GOOGLE_API_KEY
.claude/secrets.env
