{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(fd:*)",
      "Bash(pwd:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(echo:*)",
      "Bash(sort:*)",
      "Bash(diff:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(pbcopy)",
      "Bash(pbcopy:*)",
      "Bash(clip.exe)",
      "Bash(clip.exe:*)",
      "Bash(Set-Clipboard:*)",
      "Bash(graphify query *)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git push)",
      "Bash(git -C upstream/* push:*)",
      "Bash(git -C upstream/* push)"
    ]
  }
}
